# Copy this file to env/.env for local development, or to env/.env.prod for the
# droplet (docker compose reads env/.env.prod). Never commit the filled-in copies.

# ---- Core ----
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Local Postgres + PostGIS (matches `make dev-db`). The postgis:// scheme keeps
# GeoDjango's database backend.
DATABASE_URL=postgis://admin:changeme@localhost:5432/wagon_db

# ---- Production only (env/.env.prod on the droplet) ----
# DEBUG=false
# DOMAIN=wagon.example.com              # Caddy uses this for the TLS certificate
# PROD_HOSTS=wagon.example.com          # comma-separated; add the droplet IP if needed
# WEB_CONCURRENCY=2                     # gunicorn workers
#
# # Postgres container credentials (the db service reads these)
# POSTGRES_DB=wagon_db
# POSTGRES_USER=wagon
# POSTGRES_PASSWORD=change-me
# # Must match the POSTGRES_* values above; host is the compose service name "db"
# DATABASE_URL=postgis://wagon:change-me@db:5432/wagon_db
#
# # First admin, created on first container boot (email optional)
# FIRST_ADMIN_USERNAME=admin
# FIRST_ADMIN_PASSWORD=change-me
# FIRST_ADMIN_EMAIL=admin@example.com
#
# # Optional AWS — S3 media storage + SES email (dormant unless set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# DEFAULT_FROM_EMAIL=noreply@wagon.example.com
